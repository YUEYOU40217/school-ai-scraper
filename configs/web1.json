{
    "site_name": "範例網站_搜尋系統",
    "url_pattern": "https://example.com/api/data?p={page}", 
    "method": "POST",
    "headers": { 
        "User-Agent": "Mozilla/5.0",
        "Authorization": "Bearer YOUR_TOKEN"
    },
    "payload": {
        "search_key": "關鍵字",
        "category": "news"
    },
    "start_page": 1, 
    "end_page": 1,
    "delay": 1.0, 
    "description": "這是一個支援POST與自訂Header的通用配置"
}
